# =============================================================================
# TunerLink — required environment variables
# Copy this file to .env.local and fill in real values for local development.
# In Vercel, set these under Project Settings → Environment Variables.
# =============================================================================

# --- Supabase (required) ----------------------------------------------------
# Public — safe to expose to the browser. Used by the @supabase/supabase-js
# client in lib/supabase.ts.
NEXT_PUBLIC_SUPABASE_URL=https://iduedivniywbsgzixifh.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key-here

# Server-only — DO NOT expose to the client. Used only in server-side code
# (route handlers, server actions, edge functions) for privileged operations.
# REQUIRED for Stripe Connect, webhook handlers, and Resend email endpoints.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Stripe (required for payments) -----------------------------------------
# Get test keys at https://dashboard.stripe.com/test/apikeys
# For webhook secret: stripe.com → Developers → Webhooks → Add endpoint
#   URL: https://<your-domain>/api/stripe/webhook
#   Events: account.updated, checkout.session.completed,
#           payment_intent.payment_failed, charge.refunded, charge.dispute.created
STRIPE_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Optional — platform fee percentage (default 8). Adjust without redeploying code.
PLATFORM_FEE_PERCENT=8

# --- Resend (transactional email) -------------------------------------------
# Get an API key at https://resend.com/api-keys (free tier: 3k emails/mo)
# After domain DNS is verified, change EMAIL_FROM to use your domain.
RESEND_API_KEY=re_replace_me
EMAIL_FROM=TunerLink <hello@tunerlink.co>
EMAIL_REPLY_TO=hello@tunerlink.co
# Where shop-application notifications and admin alerts go.
ADMIN_EMAIL=davdndb@gmail.com

# --- Site config ------------------------------------------------------------
# Used for canonical URLs, SEO metadata, OAuth redirects, email links,
# Stripe redirect URLs. Update this immediately after the production domain lands.
NEXT_PUBLIC_SITE_URL=https://tunerlink.co
